# --- Data: never commit raw or derived data in this project ---
# Raw data here is simulated, but we treat it exactly as we would
# treat licensed CRSP/Compustat or restricted microdata: it is
# rebuilt from code, not stored in Git. See Chapters 6 and 8.
data/raw/
data/clean/

# --- Large / derived outputs ---
output/figures/
*.parquet

# --- Secrets: never commit credentials ---
.env
*.pem
secrets.*

# --- Python noise ---
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/

# --- OS / editor noise ---
.DS_Store
.Rhistory
